<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LaserConsole.ViewModels"
             x:Class="LaserConsole.Views.StatusPage"
             x:DataType="vm:StatusPageViewModel"
             Background="#1E1E2E"
             FontFamily="Inter,Segoe UI,system-ui,sans-serif">

  <DockPanel Margin="28,24,28,20">

    <!-- ── Page title ────────────────────────────────────────────────────── -->
    <TextBlock DockPanel.Dock="Top"
               Text="STATUS &amp; CONTROL"
               FontSize="11" FontWeight="SemiBold"
               Foreground="#6C7086" LetterSpacing="1.5"
               Margin="0,0,0,20"/>

    <!-- ── Log panel (pinned to bottom) ─────────────────────────────────── -->
    <Border DockPanel.Dock="Bottom"
            Background="#181825"
            CornerRadius="8"
            BorderBrush="#313244" BorderThickness="1"
            Height="200"
            Margin="0,16,0,0">
      <DockPanel Margin="12,10,12,10">
        <TextBlock DockPanel.Dock="Top"
                   Text="ACTIVITY LOG"
                   FontSize="10" FontWeight="SemiBold"
                   Foreground="#6C7086" LetterSpacing="1.2"
                   Margin="0,0,0,8"/>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding Log}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding}"
                           FontFamily="Consolas,Cascadia Code,monospace"
                           FontSize="12"
                           Foreground="#A6ADC8"
                           Margin="0,1"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <!-- ── Control cards ─────────────────────────────────────────────────── -->
    <StackPanel Spacing="12">

      <!-- Row 1: Pilot + Shutter -->
      <Grid ColumnDefinitions="*,16,*">

        <!-- PILOT card -->
        <Border Grid.Column="0"
                Background="#181825" CornerRadius="8"
                BorderBrush="#313244" BorderThickness="1"
                Padding="18,16">
          <StackPanel Spacing="14">
            <TextBlock Text="PILOT"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="#6C7086" LetterSpacing="1.2"/>

            <!-- Toggle -->
            <Button Command="{Binding PilotToggleCommand}"
                    Background="{Binding PilotBg}"
                    Foreground="{Binding PilotFg}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Padding="16,11"
                    FontSize="14" FontWeight="Bold"
                    CornerRadius="6"
                    Content="{Binding PilotLabel}"/>

            <!-- Blink controls -->
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <TextBlock Text="Blink" FontSize="12" Foreground="#6C7086" VerticalAlignment="Center"/>
              <NumericUpDown Value="{Binding BlinkSeconds}"
                             Minimum="1" Maximum="60" Increment="1"
                             Width="72" FontSize="12"
                             VerticalAlignment="Center"/>
              <TextBlock Text="s" FontSize="12" Foreground="#6C7086" VerticalAlignment="Center"/>
              <Button Content="GO"
                      Command="{Binding BlinkCommand}"
                      FontSize="12" FontWeight="SemiBold"
                      Padding="12,8"
                      Background="#2A2A45"
                      Foreground="#89B4FA"
                      CornerRadius="6"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- SHUTTER card -->
        <Border Grid.Column="2"
                Background="#181825" CornerRadius="8"
                BorderBrush="#313244" BorderThickness="1"
                Padding="18,16">
          <StackPanel Spacing="14">
            <TextBlock Text="SHUTTER"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="#6C7086" LetterSpacing="1.2"/>

            <Button Command="{Binding ShutterToggleCommand}"
                    Background="{Binding ShutterBg}"
                    Foreground="{Binding ShutterFg}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Padding="16,11"
                    FontSize="14" FontWeight="Bold"
                    CornerRadius="6"
                    Content="{Binding ShutterLabel}"/>
          </StackPanel>
        </Border>

      </Grid>

      <!-- Row 2: Focus Finder + Lamp Test -->
      <Grid ColumnDefinitions="*,16,*">

        <!-- FOCUS FINDER card -->
        <Border Grid.Column="0"
                Background="#181825" CornerRadius="8"
                BorderBrush="#313244" BorderThickness="1"
                Padding="18,16">
          <StackPanel Spacing="14">
            <TextBlock Text="FOCUS FINDER"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="#6C7086" LetterSpacing="1.2"/>

            <Button Command="{Binding FocusToggleCommand}"
                    Background="{Binding FocusBg}"
                    Foreground="{Binding FocusFg}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Padding="16,11"
                    FontSize="14" FontWeight="Bold"
                    CornerRadius="6"
                    Content="{Binding FocusLabel}"/>
          </StackPanel>
        </Border>

        <!-- LAMP TEST card -->
        <Border Grid.Column="2"
                Background="#181825" CornerRadius="8"
                BorderBrush="#313244" BorderThickness="1"
                Padding="18,16">
          <StackPanel Spacing="14">
            <TextBlock Text="LAMP TEST"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="#6C7086" LetterSpacing="1.2"/>

            <Button Command="{Binding LampToggleCommand}"
                    Background="{Binding LampBg}"
                    Foreground="{Binding LampFg}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Padding="16,11"
                    FontSize="14" FontWeight="Bold"
                    CornerRadius="6"
                    Content="{Binding LampLabel}"/>
          </StackPanel>
        </Border>

      </Grid>

      <!-- Shutdown -->
      <Border Background="#181825" CornerRadius="8"
              BorderBrush="#313244" BorderThickness="1"
              Padding="18,14">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="SHUTDOWN"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="#6C7086" LetterSpacing="1.2"/>
            <TextBlock Text="Powers off the controller hardware"
                       FontSize="11" Foreground="#45475A"
                       Margin="0,3,0,0"/>
          </StackPanel>
          <Button Grid.Column="1"
                  Content="SHUTDOWN"
                  Command="{Binding ShutdownCommand}"
                  FontSize="13" FontWeight="SemiBold"
                  Padding="20,10"
                  Background="#3A1E22"
                  Foreground="#F38BA8"
                  CornerRadius="6"/>
        </Grid>
      </Border>

    </StackPanel>

  </DockPanel>
</UserControl>
