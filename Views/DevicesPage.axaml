<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LaserConsole.ViewModels"
             x:Class="LaserConsole.Views.DevicesPage"
             Background="#1E1E2E"
             FontFamily="Inter,Segoe UI,system-ui,sans-serif">

  <DockPanel Margin="28,24,28,20">

    <!-- ── Header ─────────────────────────────────────────────────────────── -->
    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
      <TextBlock Text="DEVICE TREE"
                 FontSize="11" FontWeight="SemiBold"
                 Foreground="#6C7086" LetterSpacing="1.5"
                 VerticalAlignment="Center"/>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
        <ProgressBar IsIndeterminate="True"
                     Width="100" Height="4"
                     IsVisible="{Binding IsRefreshing}"
                     VerticalAlignment="Center"/>
        <Button Content="↺  Refresh"
                Command="{Binding RefreshCommand}"
                FontSize="13"
                Padding="14,7"
                CornerRadius="6"/>
      </StackPanel>
    </Grid>

    <!-- ── Split: tree + detail ──────────────────────────────────────────── -->
    <Grid ColumnDefinitions="320,*">

      <!-- Tree panel -->
      <Border Grid.Column="0"
              Background="#181825"
              CornerRadius="8"
              BorderBrush="#313244" BorderThickness="1"
              Margin="0,0,16,0">
        <ScrollViewer Padding="8">
          <TreeView ItemsSource="{Binding RootDevices}"
                    SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                    Background="Transparent">
            <TreeView.Styles>
              <Style Selector="TreeViewItem">
                <Setter Property="IsExpanded" Value="True"/>
                <Setter Property="Padding"    Value="4,3"/>
              </Style>
            </TreeView.Styles>
            <TreeView.ItemTemplate>
              <TreeDataTemplate ItemsSource="{Binding Children}">
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                  <Ellipse Width="8" Height="8"
                           Fill="{Binding StatusBrush}"
                           VerticalAlignment="Center"/>
                  <StackPanel>
                    <TextBlock Text="{Binding Name}"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#CDD6F4"/>
                    <TextBlock Text="{Binding Role}"
                               FontSize="11" Foreground="#6C7086"/>
                  </StackPanel>
                </StackPanel>
              </TreeDataTemplate>
            </TreeView.ItemTemplate>
          </TreeView>
        </ScrollViewer>
      </Border>

      <!-- Detail panel — Panel allows two overlapping children (empty/detail) -->
      <Border Grid.Column="1"
              Background="#181825"
              CornerRadius="8"
              BorderBrush="#313244" BorderThickness="1">
        <Panel>

          <!-- Empty state -->
          <TextBlock Text="Select a device to view details."
                     Foreground="#45475A" FontSize="14"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     IsVisible="{Binding HasNoSelection}"/>

          <!-- Device detail — DataContext switches to the selected DeviceNode -->
          <ScrollViewer IsVisible="{Binding HasSelection}"
                        DataContext="{Binding SelectedDevice}"
                        Padding="20,18">
            <StackPanel Spacing="20">

              <!-- Title -->
              <StackPanel Spacing="4">
                <TextBlock Text="{Binding Name}"
                           FontSize="20" FontWeight="Bold"
                           Foreground="#CDD6F4"/>
                <TextBlock Text="{Binding Role}"
                           FontSize="13" Foreground="#6C7086"/>
              </StackPanel>

              <Rectangle Height="1" Fill="#313244"/>

              <!-- Identity properties -->
              <StackPanel Spacing="10">
                <TextBlock Text="IDENTITY"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="#6C7086" LetterSpacing="1.2"/>
                <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto" RowSpacing="8">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Endpoint"
                             Foreground="#6C7086" FontSize="13"/>
                  <TextBlock Grid.Row="0" Grid.Column="1"
                             Text="{Binding Endpoint}"
                             Foreground="#CDD6F4" FontSize="13"
                             FontFamily="Consolas,monospace"/>
                  <TextBlock Grid.Row="1" Grid.Column="0" Text="Key"
                             Foreground="#6C7086" FontSize="13"/>
                  <TextBlock Grid.Row="1" Grid.Column="1"
                             Text="{Binding KeyHex}"
                             Foreground="#89B4FA" FontSize="11"
                             FontFamily="Consolas,monospace"
                             TextWrapping="Wrap"/>
                </Grid>
              </StackPanel>

              <!-- Attributes section -->
              <StackPanel Spacing="10" IsVisible="{Binding HasAttributes}">
                <Rectangle Height="1" Fill="#313244"/>
                <TextBlock Text="ATTRIBUTES"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="#6C7086" LetterSpacing="1.2"/>
                <ItemsControl ItemsSource="{Binding Attributes}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid ColumnDefinitions="120,*" Margin="0,3">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Name}"
                                   Foreground="#6C7086" FontSize="13"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Value}"
                                   Foreground="#CDD6F4" FontSize="13"
                                   FontFamily="Consolas,monospace"/>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

            </StackPanel>
          </ScrollViewer>

        </Panel>
      </Border>

    </Grid>

  </DockPanel>
</UserControl>
