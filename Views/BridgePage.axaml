<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LaserConsole.ViewModels"
             xmlns:views="using:LaserConsole.Views"
             x:Class="LaserConsole.Views.BridgePage"
             x:DataType="vm:BridgePageViewModel"
             Background="#1E1E2E"
             FontFamily="Inter,Segoe UI,system-ui,sans-serif">

  <DockPanel Margin="28,24,28,20">

    <!-- ── Page title ───────────────────────────────────────────────────── -->
    <TextBlock DockPanel.Dock="Top"
               Text="LIGHTBURN BRIDGE"
               FontSize="11" FontWeight="SemiBold"
               Foreground="#6C7086" LetterSpacing="1.5"
               Margin="0,0,0,20"/>

    <!-- ── Log (bottom) ─────────────────────────────────────────────────── -->
    <Border DockPanel.Dock="Bottom"
            Background="#181825" CornerRadius="8"
            BorderBrush="#313244" BorderThickness="1"
            Margin="0,12,0,0">
      <DockPanel Margin="12,10,12,10">
        <TextBlock DockPanel.Dock="Top"
                   Text="BRIDGE LOG"
                   FontSize="10" FontWeight="SemiBold"
                   Foreground="#6C7086" LetterSpacing="1.2"
                   Margin="0,0,0,8"/>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding Log}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding}"
                           FontFamily="Consolas,Cascadia Code,monospace"
                           FontSize="12" Foreground="#A6ADC8"
                           Margin="0,1"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <!-- ── Top: preview (left) + status cards (right) ──────────────────── -->
    <Grid ColumnDefinitions="380,16,*">

    <!-- Mark preview -->
    <StackPanel Grid.Column="0" Spacing="12">

      <Border Background="#181825" CornerRadius="8"
              BorderBrush="#313244" BorderThickness="1"
              Padding="18,16">
        <StackPanel Spacing="12">

          <!-- Tracing / marking indicator -->
          <Grid ColumnDefinitions="Auto,10,*">
            <Ellipse Width="12" Height="12" Fill="{Binding MarkStateBrush}" VerticalAlignment="Center">
              <Ellipse.Transitions>
                <Transitions>
                  <BrushTransition Property="Fill" Duration="0:0:0.15"/>
                </Transitions>
              </Ellipse.Transitions>
            </Ellipse>
            <StackPanel Grid.Column="2">
              <TextBlock Text="MARK PREVIEW" FontSize="10" FontWeight="SemiBold"
                         Foreground="#6C7086" LetterSpacing="1.2"/>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{Binding MarkStateText}" FontSize="14" Foreground="#CDD6F4" Margin="0,2,0,0"/>
                <TextBlock Text="HOLDING BUSY" FontSize="10" FontWeight="SemiBold"
                           Foreground="#F9E2AF" VerticalAlignment="Center"
                           IsVisible="{Binding SimulatedBusy}"/>
              </StackPanel>
            </StackPanel>
          </Grid>

          <!-- Preview canvas -->
          <Border CornerRadius="6" ClipToBounds="True" BorderBrush="#313244" BorderThickness="1">
            <views:MarkPreviewControl Width="340" Height="340"
                                       Lines="{Binding PreviewLines}"
                                       FieldWidthMm="{Binding FieldWidthMm}"
                                       FieldHeightMm="{Binding FieldHeightMm}"/>
          </Border>

          <!-- Legend -->
          <StackPanel Orientation="Horizontal" Spacing="14">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Rectangle Width="14" Height="3" Fill="#45B3D4" VerticalAlignment="Center"/>
              <TextBlock Text="move" FontSize="11" Foreground="#6C7086" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Rectangle Width="14" Height="3" Fill="#FAB387" VerticalAlignment="Center"/>
              <TextBlock Text="red dot (?)" FontSize="11" Foreground="#6C7086" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Rectangle Width="14" Height="3" Fill="#F38BA8" VerticalAlignment="Center"/>
              <TextBlock Text="mark" FontSize="11" Foreground="#6C7086" VerticalAlignment="Center"/>
            </StackPanel>
          </StackPanel>

          <!-- Field size -->
          <Grid ColumnDefinitions="Auto,8,Auto,16,Auto,8,Auto">
            <TextBlock Text="Field W" FontSize="11" Foreground="#6C7086" VerticalAlignment="Center"/>
            <NumericUpDown Grid.Column="2" Value="{Binding FieldWidthMm}"
                           Minimum="10" Maximum="2000" Increment="5"
                           Width="115" FontSize="12" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="4" Text="H" FontSize="11" Foreground="#6C7086" VerticalAlignment="Center"/>
            <NumericUpDown Grid.Column="6" Value="{Binding FieldHeightMm}"
                           Minimum="10" Maximum="2000" Increment="5"
                           Width="115" FontSize="12" VerticalAlignment="Center"/>
          </Grid>
          <TextBlock Text="mm — LightBurn doesn't send a bed size over the wire; set this to match your device."
                     FontSize="11" Foreground="#45475A" TextWrapping="Wrap"/>

          <Rectangle Height="1" Fill="#313244" Margin="0,4"/>

          <!-- Real-time playback -->
          <CheckBox Content="Real-time playback" IsChecked="{Binding RealtimePlayback}"
                     FontSize="12" Foreground="#CDD6F4"/>
          <Grid ColumnDefinitions="Auto,8,Auto,16,Auto,8,Auto" IsEnabled="{Binding RealtimePlayback}">
            <TextBlock Text="Mark" FontSize="11" Foreground="#6C7086" VerticalAlignment="Center"/>
            <NumericUpDown Grid.Column="2" Value="{Binding MarkSpeedMmPerSec}"
                           Minimum="1" Maximum="5000" Increment="5"
                           Width="115" FontSize="12" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="4" Text="Jump" FontSize="11" Foreground="#6C7086" VerticalAlignment="Center"/>
            <NumericUpDown Grid.Column="6" Value="{Binding JumpSpeedMmPerSec}"
                           Minimum="1" Maximum="5000" Increment="25"
                           Width="115" FontSize="12" VerticalAlignment="Center"/>
          </Grid>
          <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#45475A">
            mm/s — match your LightBurn speed settings. Paces both the preview and our busy/ready
            status from distance ÷ speed per move, so LightBurn actually waits for us instead of
            everything appearing instantly (the wire's own speed values are unconfirmed, so this
            uses these numbers instead of decoding them).
          </TextBlock>

        </StackPanel>
      </Border>

    </StackPanel>

    <!-- Status cards -->
    <StackPanel Grid.Column="2" Spacing="12">

      <!-- Status card -->
      <Border Background="#181825" CornerRadius="8"
              BorderBrush="#313244" BorderThickness="1"
              Padding="18,16">
        <Grid ColumnDefinitions="Auto,12,*">
          <Ellipse Width="12" Height="12"
                   Fill="{Binding StatusBrush}"
                   VerticalAlignment="Center"/>
          <StackPanel Grid.Column="2" VerticalAlignment="Center">
            <TextBlock Text="USB CDC BRIDGE"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="#6C7086" LetterSpacing="1.2"/>
            <TextBlock Text="{Binding StatusText}"
                       FontSize="14" Foreground="#CDD6F4"
                       Margin="0,4,0,0"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Manual port override -->
      <Border Background="#181825" CornerRadius="8"
              BorderBrush="#313244" BorderThickness="1"
              Padding="18,16">
        <Grid ColumnDefinitions="*,16,Auto">
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="SERIAL PORT"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="#6C7086" LetterSpacing="1.2"/>
            <TextBlock Text="Auto-detected by USB VID:PID 9588:9899 — leave blank unless auto-detect fails."
                       FontSize="11" Foreground="#45475A"
                       Margin="0,4,0,0" TextWrapping="Wrap"/>
          </StackPanel>
          <TextBox Grid.Column="2"
                    Text="{Binding ManualPort}"
                    PlaceholderText="e.g. COM5 or /dev/cu.usbmodem1101"
                    Width="240" FontSize="12"
                    VerticalAlignment="Center"/>
        </Grid>
      </Border>

      <!-- Idle poll activity — GetVersion/ReadPort are filtered out of the
           log below (LightBurn fires them every few ms while idle-armed);
           these light up instead so real commands stay visible in the log. -->
      <Border Background="#181825" CornerRadius="8"
              BorderBrush="#313244" BorderThickness="1"
              Padding="18,16">
        <Grid ColumnDefinitions="*,*">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Ellipse Width="12" Height="12" Fill="{Binding GetVersionBrush}" VerticalAlignment="Center">
              <Ellipse.Transitions>
                <Transitions>
                  <BrushTransition Property="Fill" Duration="0:0:0.15"/>
                </Transitions>
              </Ellipse.Transitions>
            </Ellipse>
            <StackPanel>
              <TextBlock Text="GETVERSION POLL" FontSize="10" FontWeight="SemiBold"
                         Foreground="#6C7086" LetterSpacing="1.2"/>
              <TextBlock Text="{Binding GetVersionCount}" FontSize="16" Foreground="#CDD6F4" Margin="0,2,0,0"/>
            </StackPanel>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
            <Ellipse Width="12" Height="12" Fill="{Binding ReadPortBrush}" VerticalAlignment="Center">
              <Ellipse.Transitions>
                <Transitions>
                  <BrushTransition Property="Fill" Duration="0:0:0.15"/>
                </Transitions>
              </Ellipse.Transitions>
            </Ellipse>
            <StackPanel>
              <TextBlock Text="READPORT POLL" FontSize="10" FontWeight="SemiBold"
                         Foreground="#6C7086" LetterSpacing="1.2"/>
              <TextBlock Text="{Binding ReadPortCount}" FontSize="16" Foreground="#CDD6F4" Margin="0,2,0,0"/>
            </StackPanel>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Traffic counters -->
      <Border Background="#181825" CornerRadius="8"
              BorderBrush="#313244" BorderThickness="1"
              Padding="18,16">
        <Grid ColumnDefinitions="*,*">
          <StackPanel>
            <TextBlock Text="LMC COMMANDS (excl. idle poll)"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="#6C7086" LetterSpacing="1.2"/>
            <TextBlock Text="{Binding CommandCount}"
                       FontSize="20" Foreground="#89B4FA"
                       Margin="0,4,0,0"/>
          </StackPanel>
          <StackPanel Grid.Column="1">
            <TextBlock Text="LIST ENTRIES (unhandled)"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="#6C7086" LetterSpacing="1.2"/>
            <TextBlock Text="{Binding ListEntryCount}"
                       FontSize="20" Foreground="#CBA6F7"
                       Margin="0,4,0,0"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Setup note -->
      <Border Background="#1A1A2E" CornerRadius="8"
              BorderBrush="#313244" BorderThickness="1"
              Padding="18,14">
        <StackPanel Spacing="6">
          <TextBlock Text="ABOUT"
                     FontSize="10" FontWeight="SemiBold"
                     Foreground="#6C7086" LetterSpacing="1.2"/>
          <TextBlock FontSize="12" Foreground="#A6ADC8" TextWrapping="Wrap">
            This bridge runs from app startup, independent of the Rofin connection, so LightBurn
            can detect the fake BJJCZ/LMC galvo board over the Pico's USB link at any time.
            Connect handshake is fully emulated. Mark-list decoding and translation to the
            Rofin controller are not implemented yet — list entries are counted above but not acted on.
          </TextBlock>
        </StackPanel>
      </Border>

    </StackPanel>

    </Grid>

  </DockPanel>
</UserControl>
